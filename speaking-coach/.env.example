# ─────────────────────────────────────────────
# AI Speaking Coach — Environment Configuration
# Copy this to .env.local and fill in values
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: claude | openai | ollama | lmstudio | openai-compat
LLM_PROVIDER=ollama

# Local LLM (Ollama / LM Studio)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Cloud LLM (Claude or OpenAI — leave blank if using local)
LLM_API_KEY=
# LLM_PROVIDER=claude
# LLM_MODEL=claude-3-5-haiku-20241022

# ── STT Provider ──────────────────────────────
# Options: local | openai-api | mock
STT_PROVIDER=mock

# Local Whisper server (faster-whisper)
STT_BASE_URL=http://localhost:8000
STT_MODEL=small

# OpenAI Whisper API (leave blank if using local)
STT_API_KEY=

# ── Database ──────────────────────────────────
DB_PATH=./data/speaking-coach.db

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Speaking Coach"
NODE_ENV=development
