# ── AI Speaking Coach — environment ──────────────────────────────
# Copy to .env.local and adjust. Defaults below = fully local dev.

# ── LLM ──────────────────────────────────────────────────────────
# mock | claude | openai | ollama | lmstudio | openai-compat
LLM_PROVIDER=mock
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=http://localhost:11434   # ollama / lmstudio

# ── STT ──────────────────────────────────────────────────────────
# mock | local (mlx-whisper server) | openai-api
STT_PROVIDER=mock
STT_BASE_URL=http://localhost:8000      # local mlx-whisper server
STT_MODEL=small                         # size name or full HF repo id
# STT_API_KEY=                          # only for STT_PROVIDER=openai-api

# ── Database ─────────────────────────────────────────────────────
DB_PATH=./data/speaking-coach.db
